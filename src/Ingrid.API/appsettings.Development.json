    "Connections": [
      {
        "Id": "IDI",
        "Connection": "server=localhost; port=1003; database=IDI; user=root; password=password;"
      },
      {
        "Id": "Core",
        "Connection": "server=localhost; port=1003; database=Core; user=root; password=password;"
      },
      {
        "Id": "Com",
        "Connection": "server=localhost; port=1003; database=Com; user=root; password=password;"
      },
      {
        "Id": "AccIPInfo",
        "Connection": "server=localhost; port=1003; database=AccIPInfo; user=root; password=password;"
